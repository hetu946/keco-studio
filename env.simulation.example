# Optional: embed the standalone simulation app (sibling repo `keco-simulation`, default dev port 3001).
# Copy these lines into `.env.local` and restart `next dev`.
NEXT_PUBLIC_SIMULATION_ENABLED=true
NEXT_PUBLIC_SIMULATION_ORIGIN=http://localhost:3001
# Optional: set to false to skip idle preconnect + hidden iframe warmup (saves bandwidth).
# NEXT_PUBLIC_SIMULATION_WARMUP=false
