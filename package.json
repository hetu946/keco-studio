  "scripts": {
    "dev": "next dev",
    "dev:lan": "bash scripts/dev-lan.sh",
    "dev:vercel": "vercel dev",
    "dev:vercel:prod": "vercel dev --prod",
    "dev:tunnel": "next dev & ngrok http 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "validate": "npm run lint && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:parallel": "playwright test --workers=50%",
    "test:e2e:clean": "tsx scripts/clean-remote-test-data.ts && playwright test",
    "test:e2e:sequential": "playwright test tests/e2e/specs/auth.spec.ts tests/e2e/specs/security.spec.ts tests/e2e/specs/file-upload-security.spec.ts tests/e2e/specs/happy-path.spec.ts tests/e2e/specs/destructive.spec.ts",
    "test:e2e:core": "playwright test tests/e2e/specs/happy-path.spec.ts tests/e2e/specs/destructive.spec.ts",
    "test:e2e:shard": "playwright test --shard",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:auth": "playwright test tests/e2e/specs/auth.spec.ts",
    "test:security": "playwright test tests/e2e/specs/security.spec.ts",
    "test:upload-security": "playwright test tests/e2e/specs/file-upload-security.spec.ts",
    "test:upload-security:manual": "playwright test tests/e2e/specs/file-upload-security-manual.spec.ts --headed",
    "test:happy": "playwright test tests/e2e/specs/happy-path.spec.ts",
    "test:destructive": "playwright test tests/e2e/specs/destructive.spec.ts",
    "test:e2e:edit-info": "playwright test tests/e2e/specs/edit-info.spec.ts",
    "clean:test-data": "tsx scripts/clean-remote-test-data.ts",
    "seed:api": "tsx scripts/seed-via-api.ts"
  }
